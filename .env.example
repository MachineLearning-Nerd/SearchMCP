# Web MCP Server Configuration
# Copy this file to .env and customize as needed

# ===========================================
# SearxNG Configuration
# ===========================================

# SearxNG server URL
# - For Docker: http://127.0.0.1:8080 (internal)
# - For external SearxNG: http://your-searxng-server:8080
# - For public instance: https://searx.be (rate limited)
SEARXNG_URL=http://localhost:8080

# Request timeout in seconds
# Increase for slow connections
SEARXNG_TIMEOUT=10

# ===========================================
# Relevance / Retrieval Quality
# ===========================================

# Engine profile mode
# - auto: apply query-aware engine profiles
# - off: do not pass engine filters to SearxNG
SEARCH_ENGINE_PROFILE_MODE=auto

# Comma-separated engines used for security/CVE-style queries
SEARCH_SECURITY_ENGINES=brave,bing,duckduckgo,wikipedia,github,stackoverflow

# Comma-separated engines used for general queries
# Leave empty to use SearxNG default engine mix
SEARCH_GENERAL_ENGINES=

# Candidate retrieval size before reranking
# candidate_count ~= min(SEARCH_MAX_CANDIDATES, limit * SEARCH_CANDIDATE_MULTIPLIER)
SEARCH_CANDIDATE_MULTIPLIER=5
SEARCH_MAX_CANDIDATES=30

# Minimum quality score required before using only SearxNG results
# If quality is below this threshold, Google fallback can be merged (when enabled)
SEARCH_MIN_QUALITY_SCORE=2.5

# ===========================================
# Fallback Configuration
# ===========================================

# Enable Google scraping fallback when SearxNG fails
# - true: Use Google scraping as fallback
# - false: Only use SearxNG (fail if unavailable)
FALLBACK_ENABLED=true

# ===========================================
# Rate Limiting
# ===========================================

# Maximum requests per period
# Prevents abuse and rate limiting from search engines
RATE_LIMIT_REQUESTS=30

# Rate limit period in seconds
RATE_LIMIT_PERIOD=60

# ===========================================
# Content Extraction
# ===========================================

# Maximum characters returned from fetched content
# Increase for longer articles, decrease for faster responses
MAX_CONTENT_LENGTH=10000

# Allow fetching localhost/private network URLs
# Keep false for production to reduce SSRF risk
FETCH_ALLOW_PRIVATE_NETWORK=false

# ===========================================
# Search Configuration
# ===========================================

# Default number of search results
# Users can override with limit parameter
DEFAULT_SEARCH_LIMIT=5

# ===========================================
# Logging Configuration
# ===========================================

# Logging level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use DEBUG for troubleshooting
LOG_LEVEL=INFO

# Output logs in JSON format
# - true: JSON format (useful for production/log aggregation)
# - false: Human-readable format
JSON_LOGS=false

# Container startup mode
# - true: Start SearxNG in background + MCP server in foreground (recommended for MCP stdio clients)
# - false: Use supervisord to manage both processes
MCP_STDIO_MODE=true
