# Web MCP Server Configuration
# Copy this file to .env and customize as needed

# SearxNG server URL (internal in Docker, or external)
SEARXNG_URL=http://localhost:8080

# Request timeout in seconds
SEARXNG_TIMEOUT=10

# Enable Google scraping fallback when SearxNG fails
FALLBACK_ENABLED=true

# Rate limiting: max requests per period
RATE_LIMIT_REQUESTS=30

# Rate limiting: period in seconds
RATE_LIMIT_PERIOD=60

# Max characters returned from fetched content
MAX_CONTENT_LENGTH=10000

# Default number of search results
DEFAULT_SEARCH_LIMIT=5

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Output logs in JSON format (useful for production)
JSON_LOGS=false
